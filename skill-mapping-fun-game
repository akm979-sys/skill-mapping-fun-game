<!DOCTYPE html>
<html>
<head>
<title>CM Public School Skill Assessment</title>

<style>
body { font-family: Arial; background:#eef3f9; padding:20px; }

.header {
    text-align:center;
    padding:15px;
    background:linear-gradient(45deg,#4CAF50,#2196F3);
    color:white;
    border-radius:12px;
}

.header img{
    width:80px;
    display:block;
    margin:0 auto 5px;
}

.header h1 { margin:5px; }

#timer {
    text-align:center;
    font-size:20px;
    color:red;
    margin:10px;
}

.question {
    background:white;
    padding:12px;
    margin:8px 0;
    border-radius:10px;
}

.options button{
    margin:5px;
    padding:8px 12px;
    border:none;
    border-radius:20px;
    cursor:pointer;
}

.selected { background:green; color:white; }

#submitBtn {
    display:block;
    margin:20px auto;
    padding:12px 20px;
    font-size:16px;
}

.result {
    background:white;
    padding:15px;
    border-radius:10px;
}

.bar {
    height:20px;
    background:linear-gradient(90deg,#4CAF50,#2196F3);
    border-radius:5px;
}

.skillCard { margin-bottom:15px; }
</style>
</head>

<body>

<div class="header">
<img src="cm-public-school-logo.png">
<h1>🏫 CM PUBLIC SCHOOL</h1>
<p>Skill Intelligence Assessment</p>
</div>

<div id="timer">Time Left: 600</div>

<div id="questions"></div>

<button id="submitBtn" onclick="calculate()">Submit</button>
<button onclick="shareGame()" style="
display:block;
margin:10px auto;
padding:10px 18px;
background:#ff9800;
color:white;
border:none;
border-radius:20px;
cursor:pointer;">
📤 Share This Game
</button>
<div id="result" class="result"></div>
<div style="text-align:center; margin:15px;">
    <h3>🙏 “Support Kids Skill Development Mission”
“₹10–₹50 Contribution Encouraged”</h3>
    <img src="qr.jpeg" alt="UPI QR" style="width:200px; border-radius:10px;">
    <p>UPI ID: 9044440703@IOB</p>
</div>
<script>
function shareGame(){

    let url = window.location.href;
    let text = "Test your child's intelligence & skills with this fun assessment!";

    // If mobile sharing supported
    if(navigator.share){
        navigator.share({
            title: "CM Public School Skill Assessment",
            text: text,
            url: url
        }).catch(()=>{});
    } 
    else {
        // Fallback options
        let choice = confirm("Share via WhatsApp?\nPress OK for WhatsApp or Cancel to copy link");

        if(choice){
            let whatsappURL = "https://wa.me/?text=" + encodeURIComponent(text + " " + url);
            window.open(whatsappURL, "_blank");
        } else {
            navigator.clipboard.writeText(url);
            alert("Link copied! Now share it anywhere.");
        }
    }
}
// TIMER (10 MINUTES)
let time = 600;

let timer = setInterval(()=>{
    time--;
    document.getElementById("timer").innerText = "Time Left: " + time + " sec";
    if(time<=0){
        clearInterval(timer);
        calculate();
    }
},1000);

// QUESTIONS (UNCHANGED)
let qList = [
"Writes better than average / औसत से बेहतर लिखता है",
"Tells stories or jokes / कहानियाँ सुनाता है",
"Good memory for names/dates / नाम व तिथि याद रखता है",
"Enjoys word games / शब्द खेल पसंद",
"Enjoys reading books / किताब पढ़ना पसंद",
"Spells correctly / सही लिखता है",
"Likes rhymes / तुकबंदी पसंद",
"Enjoys listening stories / कहानी सुनना पसंद",
"Good vocabulary / अच्छा शब्द भंडार",
"Speaks effectively / अच्छी तरह बोलता है",

"Asks how things work / चीजें कैसे काम करती हैं पूछता है",
"Enjoys numbers / संख्याएँ पसंद",
"Enjoys math / गणित पसंद",
"Likes logic games / तर्क खेल पसंद",
"Plays strategy games / रणनीति खेल",
"Solves puzzles / पहेली हल करता है",
"Organizes logically / व्यवस्थित करता है",
"Likes experiments / प्रयोग पसंद",
"Interested in science / विज्ञान में रुचि",
"Logical thinking strong / तार्किक सोच मजबूत",

"Visual imagination / कल्पना शक्ति",
"Reads maps/charts / नक्शा समझता है",
"Daydreams often / दिवास्वप्न देखता है",
"Enjoys drawing / चित्र बनाना पसंद",
"Good at drawing / चित्रकारी में अच्छा",
"Likes videos / वीडियो पसंद",
"Visual puzzles / दृश्य पहेली",
"Builds models / निर्माण करता है",
"Understands pictures / चित्र समझता है",
"Doodles often / डूडल बनाता है",

"Good in sports / खेल में अच्छा",
"Moves a lot / सक्रिय रहता है",
"Mimics others / नकल करता है",
"Assembles things / जोड़ता है",
"Touches/explores / छूकर समझता है",
"Likes physical activity / शारीरिक गतिविधि पसंद",
"Hand skills / हाथ का कौशल",
"Acts dramatically / अभिनय करता है",
"Body awareness / शरीर समझता है",
"Likes clay work / मिट्टी का काम",

"Sensitive to music / संगीत समझता है",
"Remembers tunes / धुन याद रखता है",
"Sings well / अच्छा गाता है",
"Plays instrument / वाद्य बजाता है",
"Rhythm sense / लय समझता है",
"Hums songs / गुनगुनाता है",
"Taps rhythm / ताल देता है",
"Sensitive to sound / ध्वनि समझता है",
"Likes music / संगीत पसंद",
"Sings songs / गाने गाता है",

"Social with others / मिलनसार",
"Natural leader / नेता जैसा",
"Gives advice / सलाह देता है",
"Street smart / समझदार",
"Works in group / समूह में काम",
"Teaches others / दूसरों को सिखाता है",
"Plays with others / साथ खेलता है",
"Has friends / दोस्त हैं",
"Empathy / सहानुभूति",
"Popular / लोकप्रिय",

"Independent / स्वतंत्र",
"Self aware / आत्मज्ञान",
"Works alone / अकेले काम",
"Unique thinking / अलग सोच",
"Has hobbies / शौक",
"Self direction / खुद निर्णय",
"Prefers alone / अकेलापन",
"Express feelings / भाव व्यक्त करता है",
"Learns from mistakes / गलतियों से सीखता है",
"Self confidence / आत्मविश्वास"
];

let answers = new Array(70).fill(0);
let container = document.getElementById("questions");

qList.forEach((q,i)=>{
    container.innerHTML += `
    <div class="question">
        <b>Q${i+1}</b> ${q}
        <div class="options">
            <button onclick="select(${i},0,this)">0</button>
            <button onclick="select(${i},1,this)">1</button>
            <button onclick="select(${i},2,this)">2</button>
            <button onclick="select(${i},3,this)">3</button>
        </div>
    </div>`;
});

function select(i,val,btn){
    answers[i]=val;
    let btns = btn.parentElement.children;
    for(let b of btns) b.classList.remove("selected");
    btn.classList.add("selected");
}

function sum(s,e){
    let t=0;
    for(let i=s;i<=e;i++) t+=answers[i-1];
    return t;
}

function level(score){
    if(score<=10) return "Underdeveloped";
    if(score<=20) return "Developing";
    if(score<=25) return "Strong";
    return "Highly Dominant";
}

function calculate(){

clearInterval(timer);

let scores = {
    Linguistic: sum(1,10),
    Logical: sum(11,20),
    Spatial: sum(21,30),
    Bodily: sum(31,40),
    Musical: sum(41,50),
    Interpersonal: sum(51,60),
    Intrapersonal: sum(61,70)
};

let careers = {
    Linguistic:["Teacher","Writer","Lawyer"],
    Logical:["Engineer","Doctor","Scientist"],
    Spatial:["Architect","Designer","Artist"],
    Bodily:["Athlete","Actor","Dancer"],
    Musical:["Singer","Musician"],
    Interpersonal:["Leader","Counselor","Teacher"],
    Intrapersonal:["Psychologist","Philosopher"]
};

let sorted = Object.entries(scores).sort((a,b)=>b[1]-a[1]);

let total = Object.values(scores).reduce((a,b)=>a+b,0);
let ultimate = Math.round((total/210)*100);

let output = `<h3>📊 Skill Report Card</h3>`;

for(let skill in scores){
let percent = (scores[skill]/30)*100;

output += `
<div class="skillCard">
<b>${skill}</b> (${scores[skill]}/30) - ${level(scores[skill])}
<div class="bar" style="width:${percent}%"></div>
Professions: ${careers[skill].join(", ")}
</div>`;
}

output += `<h3>🏆 Top 3 Skills</h3>
1. ${sorted[0][0]}<br>
2. ${sorted[1][0]}<br>
3. ${sorted[2][0]}`;

output += `<h3>🌟 Ultimate Profession Score</h3>
${ultimate}% → Visionary Life Architect`;

output += `<h3>📈 Improvement Tip</h3>
Focus on improving: ${sorted[6][0]}`;

document.getElementById("result").innerHTML = output;
}

</script>

</body>
</html>
